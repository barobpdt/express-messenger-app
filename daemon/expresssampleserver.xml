<service>
	<id>expresssampleserver.exe</id>
	<name>ExpressSampleServer</name>
	<description>Express Sample Node.js Server (카라오케/주문 시스템)</description>
	<executable>C:\APP\nodejs\node.exe</executable>
	<argument>C:\bpdt\project\express-sample\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\bpdt\project\express-sample\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>ExpressSampleServer wrapper</argument>
	<argument>--grow</argument>
	<argument>0.5</argument>
	<argument>--wait</argument>
	<argument>2</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>DESKTOP-GG17BR9</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\bpdt\project\express-sample</workingdirectory>
</service>